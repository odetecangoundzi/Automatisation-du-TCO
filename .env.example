# .env.example — Configuration TCO Automator
# Copier ce fichier en .env et adapter les valeurs pour votre environnement
# NE JAMAIS committer le fichier .env réel (il est dans .gitignore)

# ---------------------------------------------------------------------------
# Mode administrateur
# Active les commandes sensibles : bouton d'arrêt du serveur
# Valeur : true | false (défaut : false)
# ---------------------------------------------------------------------------
TCO_ADMIN_MODE=false

# ---------------------------------------------------------------------------
# Logging
# Valeurs : DEBUG | INFO | WARNING | ERROR (défaut : INFO)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Limites fichiers & entreprises
# ---------------------------------------------------------------------------
MAX_FILE_SIZE_MB=20
MAX_COMPANIES=100

# ---------------------------------------------------------------------------
# Répertoires (chemins relatifs à la racine du projet)
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads
PROJECTS_DIR=./projects
LOG_DIR=./logs

# ---------------------------------------------------------------------------
# Métier
# ---------------------------------------------------------------------------
# Taux de TVA par défaut : 0.055 | 0.10 | 0.20
TVA_DEFAULT=0.20
